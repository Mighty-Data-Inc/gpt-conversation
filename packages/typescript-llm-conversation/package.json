{
  "name": "@mightydatainc/llm-conversation",
  "version": "1.0.6",
  "description": "Utilities for managing multi-shot conversations and structured data handling in LLM applications",
  "author": "Mikhail Voloshin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mighty-Data-Inc/llm-conversation"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist-cjs/src/index.js",
      "import": "./dist/src/index.js",
      "node": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "dist-cjs"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('node:fs').writeFileSync('dist-cjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "test": "vitest run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "llm",
    "openai",
    "responses-api",
    "structured-outputs",
    "chat"
  ],
  "dependencies": {},
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^17.3.1",
    "openai": "^6.2.0",
    "@types/node": "^22.18.10",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
